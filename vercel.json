{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "crons": [
        {
            "path": "/api/cron/cleanup",
            "schedule": "0 3 * * *"
        },
        {
            "path": "/api/internal/scout/scan?mode=priority",
            "schedule": "0 */2 * * *"
        },
        {
            "path": "/api/internal/scout/scan?mode=all",
            "schedule": "10 2 * * *"
        }
    ],
    "headers": [
        {
            "source": "/api/health",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "no-cache, no-store, must-revalidate"
                }
            ]
        }
    ]
}